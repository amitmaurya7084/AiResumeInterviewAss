# Server port (Render sets this automatically, safe to leave as fallback)
PORT=8000

# MongoDB Atlas connection string (get from Atlas dashboard)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<dbname>

# Any random long string, used to sign JWT tokens
JWT_SECRET=change_this_to_a_long_random_string

# ImageKit (for resume profile image uploads)
IMAGEKIT_PRIVATE_KEY=

# AI provider used by Resume Builder's "AI Enhance" feature
# Must match: if OPENAI_BASE_URL points to Google Gemini's endpoint,
# OPENAI_API_KEY must be a real Gemini key (starts with AIzaSy...), not an OpenAI sk-... key.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-2.5-flash

# AI provider used by Interview Assistant + ATS Checker (via OpenRouter)
OPENROUTER_API_KEY=

# Set automatically by Render to "production" - only needed for local testing
NODE_ENV=development

# Deployed frontend URL(s), comma-separated if more than one
# e.g. https://your-app.vercel.app
CLIENT_URL=
